@model List<(string Title, string Url)>

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        @for (int i = 0; i < Model.Count; i++)
        {
            if (i == Model.Count - 1)
            {
                <li class="breadcrumb-item active" aria-current="page">@Model[i].Title</li>
            }
            else
            {
                <li class="breadcrumb-item"><a href="@Model[i].Url">@Model[i].Title</a></li>
            }
        }
    </ol>
</nav>