@{
    Layout = "_Layout";
    ViewData["Title"] = "Страница не найдена";
}

<div class="container text-center mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h2 class="mb-0">Ошибка 404</h2>
                </div>
                <div class="card-body">
                    <div class="display-1 text-danger mb-4">404</div>
                    <h3 class="mb-3">Страница не найдена</h3>
                    <p class="lead mb-4">Товар с указанным идентификатором не существует или был удален.</p>
                    <p class="mb-4">Пожалуйста, проверьте правильность ссылки или вернитесь на главную страницу.</p>
                    <a href="/" class="btn btn-primary">Вернуться на главную</a>
                    <a href="/Home/Products" class="btn btn-secondary ms-2">Перейти к товарам</a>
                </div>
            </div>
        </div>
    </div>
</div>