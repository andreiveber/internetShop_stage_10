@model InternetShop.ViewModels.ContactViewModel
@{
    Layout = "_Layout";
}

@if (!string.IsNullOrEmpty(Model.UserName))
{
    <div class="alert alert-success">
        Привет, @Model.UserName! Спасибо, что посетили наш магазин.
    </div>
}

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Контактная информация</h4>
            </div>
            <div class="card-body">
                <h5 class="card-title">Наш адрес:</h5>
                <p class="card-text">@Model.Address</p>
                
                <h5 class="card-title mt-4">Телефон:</h5>
                <p class="card-text">@Model.Phone</p>
                
                <h5 class="card-title mt-4">Email:</h5>
                <p class="card-text">@Model.Email</p>
                
                <h5 class="card-title mt-4">Часы работы:</h5>
                <p class="card-text">Время работы: @Model.WorkingHours</p>
            </div>
        </div>
    </div>
</div>