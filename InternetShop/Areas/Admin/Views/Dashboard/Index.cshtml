@{
    Layout = "_Layout";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="alert alert-primary">
                <h2>Панель администратора</h2>
                <p>Добро пожаловать в административную панель интернет-магазина SOTCOMM</p>
            </div>
        </div>
    </div>

    @await Component.InvokeAsync("AdminStats")
    
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4>Быстрые ссылки</h4>
                </div>
                <div class="card-body">
                    <a href="/admin/dashboard/stats" class="btn btn-primary me-2">Статистика</a>
                    <a href="/admin/dashboard/product/5" class="btn btn-secondary">Просмотр товара #5</a>
                    <a href="/" class="btn btn-outline-primary">Вернуться на сайт</a>
                </div>
            </div>
        </div>
    </div>
</div>