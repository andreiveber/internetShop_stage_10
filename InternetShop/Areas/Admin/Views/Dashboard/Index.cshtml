@{
    Layout = "_Layout";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="alert alert-primary">
                <h2>Панель администратора</h2>
                <p>Добро пожаловать в административную панель интернет-магазина SOTCOMM</p>
            </div>
        </div>
    </div>

    @await Component.InvokeAsync("AdminStats")
    
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h4>Быстрые ссылки</h4>
                </div>
                <div class="card-body">
                    <div class="d-flex gap-3 flex-wrap justify-content-start">
                        <a href="/admin/dashboard/stats" class="btn btn-primary" style="min-width: 180px;">Статистика</a>
                        <a href="/admin/dashboard/product/5" class="btn btn-secondary" style="min-width: 180px;">Просмотр товара #5</a>
                        <a href="/" class="btn btn-outline-primary" style="min-width: 180px;">Вернуться на сайт</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>